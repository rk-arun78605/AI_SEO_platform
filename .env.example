# ─────────────────────────────────────────────────────────────────
# RankFlow AI — Environment Variables
# Copy this file to .env.local and fill in your real credentials.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────

# ── Google Search Console (service account) ──────────────────────
# Create a service account in Google Cloud Console, download the JSON key,
# then copy the values below from that file.
# Add the service account email as an "Owner" in each client's GSC property.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private_key value from the JSON key file.
# Keep the -----BEGIN/END PRIVATE KEY----- lines and replace \n with actual newlines,
# OR store the whole key on one line with literal \n escape sequences.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Google PageSpeed Insights ─────────────────────────────────────
# Free API key from: https://console.cloud.google.com → Enable "PageSpeed Insights API"
GOOGLE_PAGESPEED_API_KEY=AIzaSy...

# ── AWS DynamoDB for homepage lead captures ─────────────────────
# Use an IAM role/user with DynamoDB permissions for these tables.
# In Amplify, prefer the app's IAM role. Static keys below are optional.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
LEADS_TABLE_NAME=indra-seo-leads
MODEL_FEEDBACK_TABLE_NAME=indra-seo-model-feedback
CONNECTORS_TABLE_NAME=indra-seo-connectors
SCAN_HISTORY_TABLE_NAME=indra-seo-scan-history

# ── AWS Bedrock model inference for SEO intelligence ───────────
# Example model IDs:
# anthropic.claude-3-5-sonnet-20240620-v1:0
# amazon.nova-pro-v1:0
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ── Optional cross-model intelligence (OpenAI) ───────────────────
# Example model: gpt-5.3-codex (or latest available in your account)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-codex

# ── Google OAuth for per-user tool linking ────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Example callback: https://www.indraseo.com/api/integrations/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# ── Optional traffic/channel connectors ───────────────────────────
# Set these to enable connector status for analytics integrations.
GA4_PROPERTY_ID=
META_ADS_ACCOUNT_ID=
YOUTUBE_CHANNEL_ID=

# ── Default website to analyse ───────────────────────────────────
# The dashboard will show data for this site when no ?siteUrl= param is given.
# Use the exact URL registered in Google Search Console (e.g. https://example.com/).
NEXT_PUBLIC_DEFAULT_SITE_URL=https://yourwebsite.com/

# ── NextAuth (add when you add authentication) ───────────────────
# Run: openssl rand -base64 32   to generate NEXTAUTH_SECRET
# NEXTAUTH_SECRET=your-random-secret
# NEXTAUTH_URL=http://localhost:3000

# ── Vercel deployment (used by GitHub Actions secrets, not .env.local) ──
# VERCEL_TOKEN=       → GitHub secret
# VERCEL_ORG_ID=      → GitHub secret
# VERCEL_PROJECT_ID=  → GitHub secret

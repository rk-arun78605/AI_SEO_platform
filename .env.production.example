# ─────────────────────────────────────────────────────────────────
# indraseo.com — Production Environment Variables
# Set ALL of these in:
#   • Vercel:       Project → Settings → Environment Variables
#   • Namecheap:    cPanel → Setup Node.js App → Environment Variables
#   • AWS Amplify:  App Settings → Environment Variables
# NEVER commit real values to Git.
# ─────────────────────────────────────────────────────────────────

# ── Site URL (required) ───────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_SITE_URL=https://indraseo.com

# ── OTP Session Signing (required) ───────────────────────────────
# Generate with: openssl rand -base64 32
OTP_SESSION_SECRET=replace-with-64-char-random-string

# ── Google PageSpeed Insights (required) ─────────────────────────
# Get from: https://console.cloud.google.com → Enable PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=AIzaSy...

# ── Google Search Console Service Account (required for dashboard)
# Create service account in Google Cloud → download JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── AWS DynamoDB — Lead & Data Storage (optional) ─────────────────
# Only required if you want to persist leads/feedback to DynamoDB
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
LEADS_TABLE_NAME=indra-seo-leads
MODEL_FEEDBACK_TABLE_NAME=indra-seo-model-feedback
CONNECTORS_TABLE_NAME=indra-seo-connectors
SCAN_HISTORY_TABLE_NAME=indra-seo-scan-history

# ── AWS Bedrock — AI Model Inference (required for SEO AI features)
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ── OpenAI (optional) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Google OAuth — per-user tool linking (optional) ───────────────
GOOGLE_OAUTH_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_SECRET=...
GOOGLE_OAUTH_REDIRECT_URI=https://indraseo.com/api/integrations/google/callback

# ── Analytics connector IDs (optional) ───────────────────────────
GA4_PROPERTY_ID=
META_ADS_ACCOUNT_ID=
YOUTUBE_CHANNEL_ID=
